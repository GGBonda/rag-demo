# ===========================================
# RAG 知识库 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# -------- Embedding 模型配置 --------
# 模型后端: openai | huggingface | ollama
EMBEDDING_BACKEND=openai

# OpenAI 配置 (EMBEDDING_BACKEND=openai 时使用)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# HuggingFace 配置 (EMBEDDING_BACKEND=huggingface 时使用)
# 例如: BAAI/bge-small-zh-v1.5 适用于中文
#       sentence-transformers/all-MiniLM-L6-v2 适用于英文
HF_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Ollama 配置 (EMBEDDING_BACKEND=ollama 时使用)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -------- PGvector 数据库配置 --------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=rag_knowledge_base
PG_USER=postgres
PG_PASSWORD=postgres
# PGvector 表名
PG_TABLE_NAME=documents

# -------- 文档分片配置 --------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
